{
  "name": "gitomic",
  "version": "0.0.1",
  "description": "Atomic, merge-free state commits over git: compare-and-swap on a ref with semantic replay.",
  "keywords": [
    "atomic",
    "cas",
    "compare-and-swap",
    "database",
    "event-sourcing",
    "git",
    "optimistic-concurrency",
    "state",
    "transaction"
  ],
  "homepage": "https://github.com/beorn/gitomic#readme",
  "bugs": "https://github.com/beorn/gitomic/issues",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beorn/gitomic.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./iso": {
      "types": "./dist/iso.d.ts",
      "import": "./dist/iso.js"
    },
    "./mem": {
      "types": "./dist/mem.d.ts",
      "import": "./dist/mem.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bench": "bun benchmarks/backends.ts",
    "build": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "check": "bun run format && bun run lint && bun run typecheck && bun run test && bun run build",
    "format": "oxfmt --check .",
    "format:write": "oxfmt .",
    "lint": "oxlint src tests benchmarks",
    "prepack": "bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:stress": "vitest run --config vitest.stress.config.ts",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "isomorphic-git": "^1.38.7",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "unstorage": "^1.17.5",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "isomorphic-git": "^1.38.7"
  },
  "peerDependenciesMeta": {
    "isomorphic-git": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.13"
}
